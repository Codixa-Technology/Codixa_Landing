# EmailJS — https://dashboard.emailjs.com
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx

# Enquiry that lands in the company inbox
VITE_EMAILJS_NOTIFY_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_NOTIFY_TEMPLATE_ID=template_xxxxxxx

# Confirmation that goes back to the visitor (optional — skipped if unset)
VITE_EMAILJS_REPLY_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_REPLY_TEMPLATE_ID=template_xxxxxxx
